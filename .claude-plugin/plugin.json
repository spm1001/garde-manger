{
  "name": "garde-manger",
  "version": "0.3.1",
  "description": "Persistent searchable memory across Claude sessions. Requires: garde CLI (uv tool install garde-manger)",
  "author": {
    "name": "Sameer Modha",
    "url": "https://github.com/spm1001"
  },
  "repository": "https://github.com/spm1001/garde-manger",
  "license": "MIT",
  "keywords": [
    "memory",
    "search",
    "sessions",
    "history"
  ],
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/ensure-garde.sh"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/session-end.sh"
          }
        ]
      }
    ]
  }
}
